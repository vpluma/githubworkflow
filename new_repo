CREATE NEW GITHUB REPO
----------------------
# 1) Go to your project folder
cd /path/to/yourPersonalLocalDirectory/yourProjectFolder

# 2) Initialize Git
git init

# 3) Set your identity for this repo
git config user.name "Firstname Lastname"
git config user.email "gmail_username@gmail.com"

# 4) Check status
git status

# 5) Add everything in the current project folder
git add .

# 6) Make your first commit
git commit -m "Initial commit"

# 7) Rename the default branch to main
git branch -M main

# 8) Add your GitHub remote
git remote add origin https://github.com/username/project_repo_name.git

# 9) Push to GitHub
git push -u origin main
